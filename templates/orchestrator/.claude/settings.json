{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "ToolSearch",
      "CronCreate",
      "CronList",
      "CronDelete",
      "Skill",
      "Agent"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-context-status",
    "refreshInterval": 300,
    "timeout": 2
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-planmode-telegram",
            "timeout": 1860
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-permission-telegram",
            "timeout": 1860
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-loop-detector",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-ask-telegram",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" crash-alert",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CTX_NODE__\" \"__CTX_CLI__\" bus hook-compact-telegram",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
